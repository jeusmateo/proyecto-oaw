---
import MainLayout from "../components/MainLayout";
import Layout from "../layouts/Layout.astro";
import BackgroundEffects from "../components/BackgroundEffects";
import "../styles/global.css";
---

<Layout>
	<BackgroundEffects client:idle />

	<div
		class="relative z-10 max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12 min-h-screen flex flex-col"
	>
		<header
			class="mb-8 lg:mb-12 flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-white/10 pb-8"
		>
			<div>
				<div class="flex items-center gap-4 mb-3">
					<div
						class="relative w-12 h-12 rounded-2xl bg-gradient-to-br from-cyan-400 via-blue-500 to-purple-600 p-[2px] shadow-[0_0_30px_rgba(6,182,212,0.4)]"
					>
                        <div class="w-full h-full bg-black/80 backdrop-blur-xl rounded-xl flex items-center justify-center">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="url(#gradient)"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                >
                                <defs>
                                    <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" stop-color="#22d3ee" />
                                    <stop offset="100%" stop-color="#c084fc" />
                                    </linearGradient>
                                </defs>
                                <path d="M4 11a9 9 0 0 1 9 9"></path>
                                <path d="M4 4a16 16 0 0 1 16 16"></path>
                                <circle cx="5" cy="19" r="1.5" fill="#22d3ee" stroke="none"></circle>
                            </svg>
                        </div>
					</div>
					<h1
						class="text-4xl md:text-6xl font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-br from-white via-cyan-100 to-cyan-400 drop-shadow-[0_0_15px_rgba(34,211,238,0.3)] animate-in slide-in-from-left duration-700"
					>
						NexusFeed
					</h1>
				</div>
                <p class="text-cyan-400/60 font-medium tracking-wide uppercase text-xs ml-[64px] animate-in slide-in-from-left duration-700 delay-100">Lector Premium de Noticias</p>
			</div>
			<div
				class="text-xs font-bold tracking-widest text-fuchsia-300 bg-fuchsia-900/20 px-4 py-2 rounded-full border border-fuchsia-500/30 self-start md:self-auto backdrop-blur-md shadow-[0_0_15px_rgba(217,70,239,0.2)] animate-in fade-in slide-in-from-right duration-700 delay-300"
			>
				v 2.0 CYBER
			</div>
		</header>

		<MainLayout client:load />
	</div>
</Layout>
