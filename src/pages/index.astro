---
import MainLayout from '../components/MainLayout';
import '../styles/global.css';

---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>NexusFeed - Lector Premium de Noticias</title>
	</head>
	<body class="bg-[#050505] min-h-screen text-slate-100 font-sans selection:bg-teal-500/30 overflow-x-hidden antialiased">
		
		{/* Background decorative elements */}
		<div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
			<div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] rounded-full bg-teal-600/10 blur-[150px] animate-pulse duration-1000"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-emerald-600/10 blur-[150px] animate-pulse duration-1000" style="animation-delay: 2s;"></div>
			<div class="absolute top-[40%] left-[80%] w-[30%] h-[30%] rounded-full bg-blue-600/5 blur-[120px]"></div>
		</div>

		<div class="relative z-10 max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12 min-h-screen flex flex-col">
			
			<header class="mb-8 lg:mb-12 flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-white/5 pb-8">
				<div>
					<div class="flex items-center gap-3 mb-3">
						<div class="w-10 h-10 rounded-xl bg-gradient-to-br from-teal-400 to-emerald-600 flex items-center justify-center shadow-lg shadow-teal-500/20">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
						</div>
						<h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-teal-400 via-emerald-400 to-teal-500 animate-in slide-in-from-left duration-500">
							NexusFeed
						</h1>
					</div>
					
				</div>
				<div class="text-sm font-medium text-emerald-400/80 bg-emerald-400/10 px-4 py-2 rounded-full border border-emerald-400/20 self-start md:self-auto animate-in fade-in slide-in-from-right duration-700 delay-300">
					V 1.0.0
				</div>
			</header>

			<MainLayout client:load />

		</div>
	</body>
</html>
